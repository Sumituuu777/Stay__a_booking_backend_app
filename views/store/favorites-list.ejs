<%-include('../partials/head') %>
<body class="bg-gray-900">

    <!-- Navbar -->
    <%-include('../partials/nav') %>

    <!-- Main Content -->
    <div class="p-6 mt-8">
        <h2 class="text-5xl font-bold text-red-500 mb-10 text-center">
            favorites
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

            <% favorites.forEach(home=>{ %>

                <!-- Image -->

                    <div class="group relative rounded-3xl overflow-hidden
                                bg-white/5
                                backdrop-blur-xl
                                border border-white/10
                                shadow-2xl
                                hover:-translate-y-1
                                hover:border-red-400/40
                                transition-all duration-500">

                        <img src="<%= home.image || home.photoURL || 'https://via.placeholder.com/500' %>"
                                alt="<%= home.houseName %>" class="w-full h-64 object-cover">

                        <div class="p-6">

                                    <!-- Location + Rating -->

                            <div class="flex justify-between items-center mb-4">

                                <div class="flex items-center gap-2">

                                    <span class="text-red-400 text-sm">📍</span>

                                    <span class="text-gray-300 text-sm font-medium">
                                        <%= home.location || "Unknown Location" %>
                                    </span>

                                    </div>

                                        <div class="flex items-center gap-1">

                                            <span class="text-yellow-400">⭐</span>

                                            <span class="text-yellow-300 font-semibold">
                                                <%= home.rating || "4.8" %>
                                            </span>

                                        </div>

                                    </div>

                                    <!-- House Name -->

                                    <h3 class="text-2xl font-bold
                                                mb-3
                                                text-white
                                                group-hover:text-red-300
                                                transition">

                                        <%= home.houseName %>

                                    </h3>

                                    <!-- Price -->

                                    <div class="mb-6">

                                        <span class="text-2xl font-bold text-white">

                                            ₹<%= home.price || "1000" %>

                                        </span>

                                        <span class="text-gray-400">

                                            / night

                                        </span>

                                    </div>

                                    <!-- Buttons -->

                                    <div class="flex items-center gap-3">

                                        <!-- View Details -->

                                        <a href="/home/<%= home._id %>" class="px-5 py-2.5
                                                rounded-lg
                                                bg-[#3b5edb]
                                                hover:bg-[#2f4fc3]
                                                text-white
                                                text-sm
                                                font-medium
                                                shadow-lg
                                                transition-all
                                                duration-300
                                                cursor-pointer">

                                             Details

                                        </a>
                                        <% if(home.isBooked){ %>
                                            <a title=' till <%= new Date(home.bookingExpiry).toLocaleString("en-GB",{day:"numeric",month:"short",hour:"numeric",minute:"2-digit",hour12:true}) %>' class="px-5 py-2.5 cursor-not-allowed
                                                        rounded-lg
                                                        border border-green-500
                                                        bg-transparent
                                                        text-green-500
                                                        text-sm
                                                        font-medium">

                                                Booked

                                            </a>
                                        <% }else{ %>
                                            <a href="/book/<%= home._id %>" class="px-5 py-2.5
                                                        rounded-lg
                                                        bg-gradient-to-r
                                                        from-pink-500
                                                        to-red-500
                                                        hover:from-pink-400
                                                        hover:to-red-400
                                                        text-white
                                                        text-sm
                                                        font-medium
                                                        shadow-lg
                                                        hover:shadow-red-500/40
                                                        transition-all
                                                        duration-300">

                                                Book
                                            </a>
                                        <% } %>
                                        
                                        <a href="/remove-fav/<%= home._id %>" class="px-5 py-2.5
                                                        rounded-lg
                                                        bg-gradient-to-r
                                                        from-pink-500
                                                        to-red-500
                                                        hover:from-pink-400
                                                        hover:to-red-400
                                                        text-white
                                                        text-sm
                                                        font-medium
                                                        shadow-lg
                                                        hover:shadow-red-500/40
                                                        transition-all
                                                        duration-300">

                                                Remove

                                        </a>
                                    </div>

                                </div>

                        </div>
                        <% }) %>
                </div>
    </div>

</body>
</html>
